# Nymbus Sandbox Environment
# Copy to .env and adjust as needed.

# Server
PORT=3040
NODE_ENV=development

# Sandbox base URL (for docs and OAuth redirects)
SANDBOX_BASE_URL=http://localhost:3040

# OAuth / Developer credentials
# In production sandbox, these would be issued per developer via a portal.
# For local dev, we use a single client for testing.
OAUTH_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_DAYS=30

# Optional: seed client for quick testing (client_id / client_secret)
SANDBOX_DEFAULT_CLIENT_ID=sandbox_dev_001
SANDBOX_DEFAULT_CLIENT_SECRET=sandbox_secret_change_in_production

# Persistence (SQLite durable store)
# SANDBOX_SQLITE_PATH=.data/nymbus-sandbox.sqlite
# SANDBOX_SQLITE_RESET_ON_BOOT=false
